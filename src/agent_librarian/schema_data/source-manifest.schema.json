{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-librarian/source-manifest.schema.json",
  "title": "Agent Librarian Source Snapshot Manifest",
  "description": "Provenance and approved-scope metadata for a local snapshot exported from an external source before agent-librarian catalogs it.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_snapshot_id",
    "source_system",
    "approved_scope",
    "local_snapshot",
    "export",
    "exported_files",
    "excluded_paths",
    "sensitivity",
    "review"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "source_snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "source_system": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "provider_hint",
        "source_locator"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "provider_hint": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_locator": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "approved_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "approved_by",
        "approved_at",
        "included_roots",
        "excluded_roots",
        "allowed_extensions",
        "max_depth",
        "notes"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "approved_by": {
          "type": "string",
          "minLength": 1
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        },
        "included_roots": {
          "$ref": "#/$defs/nonEmptyUniqueStrings"
        },
        "excluded_roots": {
          "$ref": "#/$defs/stringList"
        },
        "allowed_extensions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\.[A-Za-z0-9]+$"
          },
          "uniqueItems": true,
          "minItems": 1
        },
        "max_depth": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "notes": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "local_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root_path",
        "created_by",
        "catalog_ready"
      ],
      "properties": {
        "root_path": {
          "type": "string",
          "minLength": 1
        },
        "created_by": {
          "type": "string",
          "minLength": 1
        },
        "catalog_ready": {
          "type": "boolean"
        }
      }
    },
    "export": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exported_at",
        "method",
        "tool_name",
        "tool_version",
        "source_access_read_only"
      ],
      "properties": {
        "exported_at": {
          "type": "string",
          "format": "date-time"
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "tool_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "tool_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_access_read_only": {
          "const": true
        }
      }
    },
    "exported_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "snapshot_path",
          "source_path",
          "media_type",
          "size_bytes",
          "sha256",
          "last_modified_at",
          "classification",
          "notes"
        ],
        "properties": {
          "snapshot_path": {
            "type": "string",
            "minLength": 1
          },
          "source_path": {
            "type": "string",
            "minLength": 1
          },
          "media_type": {
            "type": "string",
            "minLength": 1
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "last_modified_at": {
            "type": "string",
            "format": "date-time"
          },
          "classification": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "$ref": "#/$defs/stringList"
          }
        }
      }
    },
    "excluded_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sensitivity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "generated_outputs_inherit_sensitivity",
        "may_commit_snapshot",
        "may_commit_generated_outputs",
        "notes"
      ],
      "properties": {
        "level": {
          "enum": [
            "public-synthetic",
            "public",
            "internal",
            "private-local",
            "restricted"
          ]
        },
        "generated_outputs_inherit_sensitivity": {
          "const": true
        },
        "may_commit_snapshot": {
          "type": "boolean"
        },
        "may_commit_generated_outputs": {
          "type": "boolean"
        },
        "notes": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_required",
        "review_owner",
        "review_status",
        "review_notes"
      ],
      "properties": {
        "review_required": {
          "const": true
        },
        "review_owner": {
          "type": "string",
          "minLength": 1
        },
        "review_status": {
          "enum": [
            "not-reviewed",
            "reviewed",
            "example-only"
          ]
        },
        "review_notes": {
          "$ref": "#/$defs/stringList"
        }
      }
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "nonEmptyUniqueStrings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "minItems": 1
    }
  }
}
